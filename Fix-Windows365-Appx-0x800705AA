
<#
.SYNOPSIS
  One-click repair for Windows 365 app installation error 0x800705AA (Insufficient system resources / app execution alias registration issues).

.DESCRIPTION
  - Auto elevate to Administrator and transcript logging
  - Environment & resource checks: disk, memory, PATH (WindowsApps)
  - TEMP cleanup to free resources
  - Reset Microsoft Store cache (wsreset)
  - Repair system image and files (DISM / SFC)
  - Ensure related services (AppXSVC, ClipSVC) are running
  - Remove leftover/damaged Windows 365 packages (including provisioned packages)
  - Reinstall Windows 365 via winget from Microsoft Store
  - Export AppX deployment-related event logs

.NOTES
  Author: M365 Copilot
  Run as Administrator; close other heavy apps to free resources.
#>

#region Elevation & logging
# Elevate to Administrator if not already
$curr = [Security.Principal.WindowsIdentity]::GetCurrent()
$principal = New-Object Security.Principal.WindowsPrincipal($curr)
if (-not $principal.IsInRole([Security.Principal.WindowsBuiltinRole]::Administrator)) {
    Write-Host "Requesting administrative privileges..." -ForegroundColor Yellow
    $arg = "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    Start-Process -FilePath "powershell.exe" -ArgumentList $arg -Verb RunAs
    exit
}

# Log directory and file
$stamp = (Get-Date).ToString('yyyyMMdd_HHmmss')
$LogRoot = Join-Path $env:USERPROFILE "Desktop\Win365_Fix_$stamp"
New-Item -Path $LogRoot -ItemType Directory -Force | Out-Null
$LogFile = Join-Path $LogRoot "Fix.log"

Start-Transcript -Path $LogFile -Append | Out-Null
Write-Host "Log path: $LogFile" -ForegroundColor Cyan
#endregion

function Write-Section($title) {
    Write-Host "`n==== $title ====" -ForegroundColor Green
}

try {
    Write-Section "Environment & Resource Checks"

    # OS info
    $os = Get-CimInstance Win32_OperatingSystem
    $ComputerName = $env:COMPUTERNAME
    $OSCaption = $os.Caption
    $OSVersion = $os.Version
    Write-Host "Computer: $ComputerName" -ForegroundColor Gray
    Write-Host "OS: $OSCaption ($OSVersion)" -ForegroundColor Gray

    # Disk space (C:)
    $minGB = 10
    $cdrive = Get-PSDrive -Name C -ErrorAction SilentlyContinue
    if ($cdrive) {
        $freeGB = [math]::Round($cdrive.Free/1GB,2)
        $totalGB = [math]::Round($cdrive.Used/1GB + $freeGB,2)
        Write-Host ("C: Free: {0} GB / Total {1} GB" -f $freeGB, $totalGB)
        if ($freeGB -lt $minGB) {
            Write-Warning "Low free space on C: (< ${minGB}GB). The script will attempt TEMP cleanup; target ≥ 15GB free for stability."
        }
    } else {
        Write-Warning "Failed to query C: drive info."
    }

    # Memory
    if ($os.TotalVisibleMemorySize -gt 0) {
        $totalMB = [math]::Round($os.TotalVisibleMemorySize/1024,0)
        $freeMB  = [math]::Round($os.FreePhysicalMemory/1024,0)
        $usedPct = [math]::Round((($totalMB - $freeMB)/$totalMB)*100,0)
        Write-Host ("Memory: {0} MB (Used {1}%)" -f $totalMB, $usedPct)
        if ($usedPct -gt 85) {
            Write-Warning "High memory usage detected. Consider closing heavy apps (browsers/IDEs/VMs) to avoid resource shortages."
        }
    }

    # Ensure WindowsApps in user PATH
    $windowsApps = Join-Path $env:LOCALAPPDATA "Microsoft\WindowsApps"
    $userPath = [Environment]::GetEnvironmentVariable("Path","User")
    if ($null -eq $userPath) { $userPath = "" }
    if (-not (Test-Path $windowsApps)) {
        Write-Warning "Path not found: $windowsApps (used by App Execution Aliases)."
    } elseif ($userPath -notmatch [Regex]::Escape($windowsApps)) {
        try {
            [Environment]::SetEnvironmentVariable("Path", ($userPath.TrimEnd(';') + ";" + $windowsApps), "User")
            Write-Host "Added WindowsApps to user PATH. A sign-out/reboot may be required for shells to pick up changes." -ForegroundColor Yellow
        } catch {
            Write-Warning "Failed to add WindowsApps to PATH: $($_.Exception.Message)"
        }
    } else {
        Write-Host "WindowsApps already present in PATH."
    }

    Write-Section "Freeing Resources: TEMP Cleanup"
    $tempPaths = @($env:TEMP, "$env:WINDIR\Temp")
    foreach ($p in $tempPaths) {
        if (Test-Path $p) {
            Write-Host "Cleaning: $p"
            try {
                Get-ChildItem $p -Force -ErrorAction SilentlyContinue | 
                    Where-Object { -not $_.PsIsContainer } | 
                    Remove-Item -Force -ErrorAction SilentlyContinue
                Get-ChildItem $p -Directory -Force -ErrorAction SilentlyContinue | 
                    ForEach-Object {
                        try { Remove-Item $_.FullName -Recurse -Force -ErrorAction SilentlyContinue } catch {}
                    }
            } catch {
                Write-Warning "Cleanup issue at $p: $($_.Exception.Message)"
            }
        }
    }

    Write-Section "Reset Microsoft Store Cache (wsreset)"
    try {
        Start-Process -FilePath "wsreset.exe" -Wait -WindowStyle Hidden
        Start-Sleep -Seconds 3
    } catch {
        Write-Warning "wsreset failed: $($_.Exception.Message)"
    }

    Write-Section "Repair System Image & Files (DISM / SFC) — can take a while"
    try {
        Start-Process -FilePath "dism.exe" -ArgumentList "/Online","/Cleanup-Image","/RestoreHealth" -Wait -NoNewWindow
    } catch {
        Write-Warning "DISM failed: $($_.Exception.Message)"
    }
    try {
        Start-Process -FilePath "sfc.exe" -ArgumentList "/scannow" -Wait -NoNewWindow
    } catch {
        Write-Warning "SFC failed: $($_.Exception.Message)"
    }

    Write-Section "Ensure Services Running (AppXSVC / ClipSVC)"
    $svcNames = @("AppXSVC","ClipSVC")
    foreach ($sn in $svcNames) {
        $svc = Get-Service -Name $sn -ErrorAction SilentlyContinue
        if ($null -eq $svc) {
            Write-Warning "Service not found: $sn"
            continue
        }
        if ($svc.Status -ne 'Running') {
            try {
                if ($svc.StartType -eq 'Disabled') {
                    Set-Service -Name $sn -StartupType Manual
                }
                Start-Service -Name $sn -ErrorAction SilentlyContinue
                Start-Sleep -Seconds 2
                $svc.Refresh()
                Write-Host "$sn status: $($svc.Status)"
            } catch {
                Write-Warning "Failed to start service $sn: $($_.Exception.Message)"
            }
        } else {
            Write-Host "$sn is running."
        }
    }

    Write-Section "Remove Windows 365 Leftovers (Appx packages / provisioned)"
    try {
        $targetPattern = "*Windows365*"
        $pkgList = Get-AppxPackage -AllUsers $targetPattern -ErrorAction SilentlyContinue
        if ($pkgList) {
            $pkgList | ForEach-Object {
                Write-Host "Removing user package: $($_.PackageFullName)"
                try {
                    Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction Continue
                } catch {
                    Write-Warning "Removal failed (may be corrupted or in use): $($_.Exception.Message)"
                }
            }
        } else {
            Write-Host "No user-level leftover packages found."
        }

        $provList = Get-AppxProvisionedPackage -Online | Where-Object { $_.DisplayName -like $targetPattern }
        if ($provList) {
            $provList | ForEach-Object {
                Write-Host "Removing provisioned package: $($_.DisplayName)"
                try {
                    Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName | Out-Null
                } catch {
                    Write-Warning "Provisioned package removal failed: $($_.Exception.Message)"
                }
            }
        } else {
            Write-Host "No provisioned package leftovers found."
        }
    } catch {
        Write-Warning "Error while cleaning Windows 365 leftovers: $($_.Exception.Message)"
    }

    Write-Section "Reinstall Windows 365 via winget (Microsoft Store)"
    $winget = Get-Command winget -ErrorAction SilentlyContinue
    if ($winget) {
        try {
            & winget source update --quiet | Out-Null
        } catch { }
        try {
            & winget install --id Microsoft.Windows365 --source msstore --accept-source-agreements --accept-package-agreements --force
        } catch {
            Write-Warning "winget install failed: $($_.Exception.Message)"
        }
    } else {
        Write-Warning "winget (App Installer) not detected. Install/update 'App Installer' from Microsoft Store, or install Windows 365 via Store UI."
    }

    Write-Section "Export AppX Deployment Event Logs (last 4 hours)"
    $since = (Get-Date).AddHours(-4)
    $log1 = Join-Path $LogRoot "AppxDeployment-Server.log"
    $log2 = Join-Path $LogRoot "AppxPackagingOM.log"

    try {
        Get-WinEvent -LogName "Microsoft-Windows-AppxDeployment-Server/Operational" -ErrorAction SilentlyContinue |
            Where-Object { $_.TimeCreated -ge $since -and ($_.LevelDisplayName -eq 'Error' -or $_.LevelDisplayName -eq 'Warning') } |
            Select-Object TimeCreated, Id, LevelDisplayName, Message |
            Format-List | Out-File -FilePath $log1 -Encoding UTF8
        Write-Host "Exported: $log1"
    } catch {
        Write-Warning "Failed to export AppxDeployment-Server log: $($_.Exception.Message)"
    }
    try {
        Get-WinEvent -LogName "Microsoft-Windows-AppxPackagingOM/Operational" -ErrorAction SilentlyContinue |
            Where-Object { $_.TimeCreated -ge $since -and ($_.LevelDisplayName -eq 'Error' -or $_.LevelDisplayName -eq 'Warning') } |
            Select-Object TimeCreated, Id, LevelDisplayName, Message |
            Format-List | Out-File -FilePath $log2 -Encoding UTF8
        Write-Host "Exported: $log2"
    } catch {
        Write-Warning "Failed to export AppxPackagingOM log: $($_.Exception.Message)"
    }

    Write-Section "Done"
    Write-Host "✅ Script completed. Reboot your PC and try launching/installing Windows 365 again."
    Write-Host "If it still fails, zip and share the desktop log folder ($LogRoot) so I can analyze further."
}
catch {
    Write-Host "Unhandled exception: $($_.Exception.Message)" -ForegroundColor Red
}
finally {
    Stop-Transcript | Out-Null
}
